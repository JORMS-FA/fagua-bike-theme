{
    "name": "jorms-fa/bicicleteria-fagua-theme",
    "description": "Tema personalizado para Bicicletería Fagua — child theme de Storefront con diseño premium minimalista.",
    "type": "wordpress-theme",
    "license": "GPL-2.0-or-later",
    "keywords": ["wordpress", "woocommerce", "theme", "storefront", "fagua", "bicicleteria"],
    "authors": [
        {
            "name": "Bicicletería Fagua",
            "email": "fagua.bike@gmail.com",
            "homepage": "https://github.com/JORMS-FA"
        }
    ],
    "homepage": "https://github.com/JORMS-FA/fagua-bike-theme",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpunit/phpunit": "^9.6 || ^10.5"
    },
    "autoload-dev": {
        "psr-4": {
            "BicicleteriaFagua\\Tests\\": "tests/php/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml.dist",
        "phpcbf": "phpcbf --standard=phpcs.xml.dist",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "test": "phpunit --configuration=phpunit.xml.dist",
        "verify": [
            "@phpcs",
            "@phpstan"
        ]
    },
    "support": {
        "issues": "https://github.com/JORMS-FA/fagua-bike-theme/issues",
        "source": "https://github.com/JORMS-FA/fagua-bike-theme"
    }
}
